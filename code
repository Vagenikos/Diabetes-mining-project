        "from sklearn.cluster import KMeans\n",
        "\n",
        "# Θα χρησιμοποιήσουμε δύο βασικά χαρακτηριστικά για την ομαδοποίηση: Age (Ηλικία) και BMI\n",
        "X_cluster = df[['age', 'bmi']]\n",
        "\n",
        "# Scaling ειδικά για το clustering\n",
        "scaler_cluster = StandardScaler()\n",
        "X_cluster_scaled = scaler_cluster.fit_transform(X_cluster)\n",
        "\n",
        "# Υπολογισμός του WCSS (Within-Cluster Sum of Squares) για διάφορα K\n",
        "wcss = []\n",
        "for i in range(1, 11):\n",
        "    kmeans = KMeans(n_clusters=i, init='k-means++', random_state=42, n_init=10)\n",
        "    kmeans.fit(X_cluster_scaled)\n",
        "    wcss.append(kmeans.inertia_)\n",
        "\n",
        "# Σχεδιασμός του Elbow Plot\n",
        "plt.figure(figsize=(8, 5))\n",
        "plt.plot(range(1, 11), wcss, marker='o', linestyle='--', color='purple')\n",
        "plt.title('The Elbow Method (Εύρεση Ιδανικού K)')\n",
        "plt.xlabel('Αριθμός Clusters (K)')\n",
        "plt.ylabel('WCSS')\n",
        "plt.savefig('elbow_method.png')\n",
        "plt.show()"
